# Variables d'environnement locales pour Claude Code
# Copier ce fichier en settings.local.json ou .env et remplir les valeurs
# Ne JAMAIS committer le fichier rempli dans git

# --- API Keys ---
# ANTHROPIC_API_KEY=sk-ant-...        # Clé Anthropic (gérée par ~/.claude/.credentials.json)

# --- Intégrations MCP ---
# HEYGEN_API_KEY=                     # Clé API HeyGen (voir reference_heygen.md dans memory/)
# NOTION_API_TOKEN=                   # Token Notion pour MCP notion
# GMAIL_TOKEN=                        # Token OAuth Gmail pour MCP gmail

# --- Chemins locaux ---
# CLAUDE_HOME=D:\CLAUDE_HOME          # Répertoire de travail principal
# CLAUDE_MEMORY_DIR=~/.claude/projects/D--CLAUDE-HOME/memory
